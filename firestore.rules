rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function verifiedUser() {
      return signedIn() && request.auth.token.email_verified == true;
    }

    function membershipPath(spaceId, userId) {
      return /databases/$(database)/documents/memberships/$(spaceId + "_" + userId);
    }

    function spacePath(spaceId) {
      return /databases/$(database)/documents/spaces/$(spaceId);
    }

    function invitationPath(invitationId) {
      return /databases/$(database)/documents/invitations/$(invitationId);
    }

    function activeMembership(spaceId, userId) {
      return exists(membershipPath(spaceId, userId))
        && get(membershipPath(spaceId, userId)).data.spaceId == spaceId
        && get(membershipPath(spaceId, userId)).data.userId == userId
        && get(membershipPath(spaceId, userId)).data.status == "ACTIVE";
    }

    function isActiveMember(spaceId) {
      return verifiedUser() && activeMembership(spaceId, request.auth.uid);
    }

    function isOwner(spaceId) {
      return isActiveMember(spaceId)
        && get(membershipPath(spaceId, request.auth.uid)).data.role == "OWNER"
        && get(spacePath(spaceId)).data.ownerId == request.auth.uid;
    }

    function validSpaceName(name) {
      return name is string && name.size() > 0 && name.size() <= 60;
    }

    function validNewSpace(spaceId) {
      let ownerMembership = getAfter(membershipPath(spaceId, request.auth.uid));
      return verifiedUser()
        && request.resource.data.keys().hasAll([
          "name",
          "ownerId",
          "createdBy",
          "memberCount",
          "lastMembershipChangeUserId",
          "createdAt",
          "updatedAt"
        ])
        && request.resource.data.keys().hasOnly([
          "name",
          "ownerId",
          "createdBy",
          "memberCount",
          "lastMembershipChangeUserId",
          "createdAt",
          "updatedAt"
        ])
        && validSpaceName(request.resource.data.name)
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.memberCount == 1
        && request.resource.data.lastMembershipChangeUserId == request.auth.uid
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time
        && ownerMembership.data.spaceId == spaceId
        && ownerMembership.data.userId == request.auth.uid
        && ownerMembership.data.role == "OWNER"
        && ownerMembership.data.status == "ACTIVE";
    }

    function validSpaceRename(spaceId) {
      return isOwner(spaceId)
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["name", "updatedAt"])
        && validSpaceName(request.resource.data.name)
        && request.resource.data.updatedAt == request.time;
    }

    function validOwnershipTransfer(spaceId) {
      let previousOwnerId = resource.data.ownerId;
      let newOwnerId = request.resource.data.ownerId;
      return isOwner(spaceId)
        && previousOwnerId == request.auth.uid
        && newOwnerId is string
        && newOwnerId != previousOwnerId
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["ownerId", "updatedAt"])
        && request.resource.data.updatedAt == request.time
        && getAfter(membershipPath(spaceId, previousOwnerId)).data.role == "MEMBER"
        && getAfter(membershipPath(spaceId, previousOwnerId)).data.status == "ACTIVE"
        && getAfter(membershipPath(spaceId, newOwnerId)).data.role == "OWNER"
        && getAfter(membershipPath(spaceId, newOwnerId)).data.status == "ACTIVE";
    }

    function validMemberCountDecrease(spaceId) {
      let targetUserId = request.resource.data.lastMembershipChangeUserId;
      return isActiveMember(spaceId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "memberCount",
          "lastMembershipChangeUserId",
          "updatedAt"
        ])
        && targetUserId is string
        && resource.data.memberCount is int
        && resource.data.memberCount > 1
        && request.resource.data.memberCount == resource.data.memberCount - 1
        && request.resource.data.updatedAt == request.time
        && exists(membershipPath(spaceId, targetUserId))
        && get(membershipPath(spaceId, targetUserId)).data.role == "MEMBER"
        && !existsAfter(membershipPath(spaceId, targetUserId))
        && (targetUserId == request.auth.uid || isOwner(spaceId));
    }

    function validMemberCountIncrease(spaceId) {
      let targetUserId = request.resource.data.lastMembershipChangeUserId;
      let membershipAfter = getAfter(membershipPath(spaceId, targetUserId));
      let invitationId = membershipAfter.data.joinedViaInvitationId;
      let invitationBefore = get(invitationPath(invitationId));
      let invitationAfter = getAfter(invitationPath(invitationId));
      return verifiedUser()
        && targetUserId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "memberCount",
          "lastMembershipChangeUserId",
          "updatedAt"
        ])
        && resource.data.memberCount is int
        && resource.data.memberCount < 10
        && request.resource.data.memberCount == resource.data.memberCount + 1
        && request.resource.data.updatedAt == request.time
        && !exists(membershipPath(spaceId, targetUserId))
        && membershipAfter.data.spaceId == spaceId
        && membershipAfter.data.userId == targetUserId
        && membershipAfter.data.role == "MEMBER"
        && membershipAfter.data.status == "ACTIVE"
        && invitationBefore.data.spaceId == spaceId
        && invitationBefore.data.status == "ACTIVE"
        && invitationBefore.data.expiresAt > request.time
        && invitationAfter.data.status == "USED"
        && invitationAfter.data.usedBy == targetUserId
        && invitationAfter.data.usedAt == request.time;
    }

    function validShoppingText(value, maxLength, required) {
      return value is string
        && value.size() <= maxLength
        && (!required || value.size() > 0);
    }

    function validOptionalShoppingText(value, maxLength) {
      return value == null || validShoppingText(value, maxLength, false);
    }

    function validShoppingItemShape() {
      return request.resource.data.keys().hasAll([
          "name",
          "quantity",
          "notes",
          "purchased",
          "createdBy",
          "createdByName",
          "createdAt",
          "updatedBy",
          "updatedAt",
          "purchasedBy",
          "purchasedByName",
          "purchasedAt"
        ])
        && request.resource.data.keys().hasOnly([
          "name",
          "quantity",
          "notes",
          "purchased",
          "createdBy",
          "createdByName",
          "createdAt",
          "updatedBy",
          "updatedAt",
          "purchasedBy",
          "purchasedByName",
          "purchasedAt",
          "supermarket",
          "brand"
        ])
        && validShoppingText(request.resource.data.name, 120, true)
        && validOptionalShoppingText(request.resource.data.quantity, 40)
        && validOptionalShoppingText(request.resource.data.notes, 500)
        && request.resource.data.purchased is bool
        && request.resource.data.createdBy is string
        && validShoppingText(request.resource.data.createdByName, 60, true)
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedBy is string
        && request.resource.data.updatedAt is timestamp
        && (!request.resource.data.keys().hasAny(["supermarket"])
          || request.resource.data.supermarket == null
          || request.resource.data.supermarket in ["DIA", "EROSKI", "MERCADONA", "CARREFOUR", "ALCAMPO", "OTROS", "INDIFERENTE"])
        && (!request.resource.data.keys().hasAny(["brand"])
          || validOptionalShoppingText(request.resource.data.brand, 60));
    }

    function validShoppingPurchaseAttribution() {
      return (
          request.resource.data.purchased == true
          && request.resource.data.purchasedBy == request.auth.uid
          && validShoppingText(request.resource.data.purchasedByName, 60, true)
          && request.resource.data.purchasedAt == request.time
        ) || (
          request.resource.data.purchased == false
          && request.resource.data.purchasedBy == null
          && request.resource.data.purchasedByName == null
          && request.resource.data.purchasedAt == null
        );
    }

    function validNewShoppingItem(spaceId) {
      return isActiveMember(spaceId)
        && validShoppingItemShape()
        && request.resource.data.purchased == false
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedBy == request.auth.uid
        && request.resource.data.updatedAt == request.time
        && request.resource.data.purchasedBy == null
        && request.resource.data.purchasedByName == null
        && request.resource.data.purchasedAt == null;
    }

    function validShoppingItemUpdate(spaceId) {
      let purchaseChanged = request.resource.data.purchased != resource.data.purchased;
      return isActiveMember(spaceId)
        && validShoppingItemShape()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "name",
          "quantity",
          "notes",
          "purchased",
          "updatedBy",
          "updatedAt",
          "purchasedBy",
          "purchasedByName",
          "purchasedAt",
          "supermarket",
          "brand"
        ])
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdByName == resource.data.createdByName
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedBy == request.auth.uid
        && request.resource.data.updatedAt == request.time
        && (
          (purchaseChanged && validShoppingPurchaseAttribution())
          || (
            !purchaseChanged
            && request.resource.data.purchasedBy == resource.data.purchasedBy
            && request.resource.data.purchasedByName == resource.data.purchasedByName
            && request.resource.data.purchasedAt == resource.data.purchasedAt
          )
        );
    }

    function validShoppingAnonymization(spaceId) {
      return isActiveMember(spaceId)
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["createdByName", "purchasedByName"])
        && ((resource.data.createdBy == request.auth.uid
            && request.resource.data.createdByName == "Usuario eliminado")
          || (resource.data.createdBy != request.auth.uid
            && request.resource.data.createdByName == resource.data.createdByName))
        && ((resource.data.purchasedBy == request.auth.uid
            && request.resource.data.purchasedByName == "Usuario eliminado")
          || (resource.data.purchasedBy != request.auth.uid
            && request.resource.data.purchasedByName == resource.data.purchasedByName));
    }

    function validOptionalTaskText(value, maxLength) {
      return value == null || (value is string && value.size() <= maxLength);
    }

    function activeTaskAssignee(spaceId, userId) {
      return userId is string
        && exists(membershipPath(spaceId, userId))
        && get(membershipPath(spaceId, userId)).data.status == "ACTIVE";
    }

    function validTaskShape(spaceId) {
      return request.resource.data.keys().hasAll([
          "title", "description", "assigneeId", "assigneeName", "dueAt",
          "priority", "status", "createdBy", "createdByName", "createdAt",
          "updatedBy", "updatedAt", "completedBy", "completedByName", "completedAt"
        ])
        && request.resource.data.keys().hasOnly([
          "title", "description", "assigneeId", "assigneeName", "dueAt",
          "priority", "status", "createdBy", "createdByName", "createdAt",
          "updatedBy", "updatedAt", "completedBy", "completedByName", "completedAt", "type",
          "recurrenceUnit", "recurrenceInterval", "startAt"
        ])
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 120
        && validOptionalTaskText(request.resource.data.description, 1000)
        && activeTaskAssignee(spaceId, request.resource.data.assigneeId)
        && request.resource.data.assigneeName is string
        && request.resource.data.assigneeName.size() > 0
        && request.resource.data.assigneeName.size() <= 60
        && (request.resource.data.dueAt == null || request.resource.data.dueAt is timestamp)
        && (!request.resource.data.keys().hasAny(["startAt"])
          || request.resource.data.startAt == null
          || request.resource.data.startAt is timestamp)
        && request.resource.data.priority in ["LOW", "MEDIUM", "HIGH"]
        && (!request.resource.data.keys().hasAny(["type"])
          || request.resource.data.type == null
          || request.resource.data.type in ["LIMPIEZA", "MEDICO", "COMPRAS", "HOGAR", "OTROS"])
        && (!request.resource.data.keys().hasAny(["recurrenceUnit"])
          || request.resource.data.recurrenceUnit == null
          || request.resource.data.recurrenceUnit in ["DAY", "WEEK", "MONTH"])
        && (!request.resource.data.keys().hasAny(["recurrenceInterval"])
          || request.resource.data.recurrenceInterval == null
          || (request.resource.data.recurrenceInterval is int
            && request.resource.data.recurrenceInterval >= 1
            && request.resource.data.recurrenceInterval <= 365))
        && request.resource.data.status in ["TODO", "DONE"]
        && request.resource.data.createdBy is string
        && request.resource.data.createdByName is string
        && request.resource.data.createdByName.size() > 0
        && request.resource.data.createdByName.size() <= 60
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedBy is string
        && request.resource.data.updatedAt is timestamp;
    }

    function validTaskCompletion() {
      return (
          request.resource.data.status == "DONE"
          && request.resource.data.completedBy == request.auth.uid
          && request.resource.data.completedByName is string
          && request.resource.data.completedByName.size() > 0
          && request.resource.data.completedByName.size() <= 60
          && request.resource.data.completedAt == request.time
        ) || (
          request.resource.data.status == "TODO"
          && request.resource.data.completedBy == null
          && request.resource.data.completedByName == null
          && request.resource.data.completedAt == null
        );
    }

    function validNewTask(spaceId) {
      return isActiveMember(spaceId)
        && validTaskShape(spaceId)
        && request.resource.data.status == "TODO"
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedBy == request.auth.uid
        && request.resource.data.updatedAt == request.time
        && request.resource.data.completedBy == null
        && request.resource.data.completedByName == null
        && request.resource.data.completedAt == null;
    }

    function validTaskUpdate(spaceId) {
      let statusChanged = request.resource.data.status != resource.data.status;
      return isActiveMember(spaceId)
        && validTaskShape(spaceId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "title", "description", "assigneeId", "assigneeName", "dueAt", "priority",
          "status", "updatedBy", "updatedAt", "completedBy", "completedByName", "completedAt", "type",
          "recurrenceUnit", "recurrenceInterval", "startAt"
        ])
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdByName == resource.data.createdByName
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedBy == request.auth.uid
        && request.resource.data.updatedAt == request.time
        && (
          (statusChanged && validTaskCompletion())
          || (
            !statusChanged
            && request.resource.data.completedBy == resource.data.completedBy
            && request.resource.data.completedByName == resource.data.completedByName
            && request.resource.data.completedAt == resource.data.completedAt
          )
        );
    }

    function validTaskAnonymization(spaceId) {
      return isActiveMember(spaceId)
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["createdByName", "assigneeName", "completedByName"])
        && ((resource.data.createdBy == request.auth.uid
            && request.resource.data.createdByName == "Usuario eliminado")
          || (resource.data.createdBy != request.auth.uid
            && request.resource.data.createdByName == resource.data.createdByName))
        && ((resource.data.assigneeId == request.auth.uid
            && request.resource.data.assigneeName == "Usuario eliminado")
          || (resource.data.assigneeId != request.auth.uid
            && request.resource.data.assigneeName == resource.data.assigneeName))
        && ((resource.data.completedBy == request.auth.uid
            && request.resource.data.completedByName == "Usuario eliminado")
          || (resource.data.completedBy != request.auth.uid
            && request.resource.data.completedByName == resource.data.completedByName));
    }

    function validEventShape() {
      return request.resource.data.keys().hasAll([
        "title", "description", "allDay", "startAt", "endAt", "startDate",
        "endDateExclusive", "timeZone", "color", "participantIds", "participantNames",
        "createdBy", "createdByName", "createdAt", "updatedBy", "updatedAt"
      ]) && request.resource.data.keys().hasOnly([
        "title", "description", "allDay", "startAt", "endAt", "startDate",
        "endDateExclusive", "timeZone", "color", "participantIds", "participantNames",
        "createdBy", "createdByName", "createdAt", "updatedBy", "updatedAt"
      ])
      && request.resource.data.title is string && request.resource.data.title.size() > 0 && request.resource.data.title.size() <= 120
      && (request.resource.data.description == null || (request.resource.data.description is string && request.resource.data.description.size() <= 1000))
      && request.resource.data.allDay is bool
      && request.resource.data.startAt is timestamp && request.resource.data.endAt is timestamp
      && request.resource.data.startAt < request.resource.data.endAt
      && request.resource.data.timeZone is string && request.resource.data.timeZone.size() > 0 && request.resource.data.timeZone.size() <= 64
      && request.resource.data.color in ["BLUE", "GREEN", "ORANGE", "PURPLE", "RED", "TEAL"]
      && request.resource.data.participantIds is list && request.resource.data.participantIds.size() <= 10
      && request.resource.data.participantNames is list && request.resource.data.participantNames.size() == request.resource.data.participantIds.size()
      && request.resource.data.createdBy is string && request.resource.data.createdByName is string
      && request.resource.data.createdByName.size() > 0 && request.resource.data.createdByName.size() <= 60
      && request.resource.data.createdAt is timestamp && request.resource.data.updatedBy is string && request.resource.data.updatedAt is timestamp
      && ((request.resource.data.allDay == true
          && request.resource.data.startDate is string && request.resource.data.endDateExclusive is string
          && request.resource.data.startDate < request.resource.data.endDateExclusive)
        || (request.resource.data.allDay == false
          && request.resource.data.startDate == null && request.resource.data.endDateExclusive == null));
    }

    function validNewEvent(spaceId) {
      return isActiveMember(spaceId) && validEventShape()
        && request.resource.data.createdBy == request.auth.uid && request.resource.data.createdAt == request.time
        && request.resource.data.updatedBy == request.auth.uid && request.resource.data.updatedAt == request.time;
    }

    function validEventUpdate(spaceId) {
      return isActiveMember(spaceId) && validEventShape()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "title", "description", "allDay", "startAt", "endAt", "startDate",
          "endDateExclusive", "timeZone", "color", "participantIds", "participantNames", "updatedBy", "updatedAt"
        ])
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdByName == resource.data.createdByName
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedBy == request.auth.uid && request.resource.data.updatedAt == request.time;
    }

    function validEventAnonymization(spaceId) {
      return isActiveMember(spaceId)
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["createdByName", "participantNames"])
        && ((resource.data.createdBy == request.auth.uid
            && request.resource.data.createdByName == "Usuario eliminado")
          || (resource.data.createdBy != request.auth.uid
            && request.resource.data.createdByName == resource.data.createdByName))
        && request.resource.data.participantIds == resource.data.participantIds
        && request.resource.data.participantNames.size() == resource.data.participantNames.size();
    }

    function validMealShape() {
      return request.resource.data.keys().hasAll([
        "date", "slot", "name", "participantIds", "participantNames",
        "createdBy", "createdByName", "createdAt", "updatedBy", "updatedAt"
      ]) && request.resource.data.keys().hasOnly([
        "date", "slot", "name", "participantIds", "participantNames",
        "createdBy", "createdByName", "createdAt", "updatedBy", "updatedAt", "recipeId"
      ])
      && (!request.resource.data.keys().hasAny(["recipeId"])
        || request.resource.data.recipeId == null
        || request.resource.data.recipeId is string)
      && request.resource.data.date is string
      && request.resource.data.date.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
      && request.resource.data.slot in ["DESAYUNO", "COMIDA", "CENA"]
      && request.resource.data.name is string && request.resource.data.name.size() > 0 && request.resource.data.name.size() <= 120
      && request.resource.data.participantIds is list && request.resource.data.participantIds.size() <= 10
      && request.resource.data.participantNames is list && request.resource.data.participantNames.size() == request.resource.data.participantIds.size()
      && request.resource.data.createdBy is string && request.resource.data.createdByName is string
      && request.resource.data.createdByName.size() > 0 && request.resource.data.createdByName.size() <= 60
      && request.resource.data.createdAt is timestamp && request.resource.data.updatedBy is string && request.resource.data.updatedAt is timestamp;
    }

    function validNewMeal(spaceId) {
      return isActiveMember(spaceId) && validMealShape()
        && request.resource.data.createdBy == request.auth.uid && request.resource.data.createdAt == request.time
        && request.resource.data.updatedBy == request.auth.uid && request.resource.data.updatedAt == request.time;
    }

    function validMealUpdate(spaceId) {
      return isActiveMember(spaceId) && validMealShape()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "date", "slot", "name", "participantIds", "participantNames", "recipeId", "updatedBy", "updatedAt"
        ])
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdByName == resource.data.createdByName
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedBy == request.auth.uid && request.resource.data.updatedAt == request.time;
    }

    function validMealAnonymization(spaceId) {
      return isActiveMember(spaceId)
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["createdByName", "participantNames"])
        && ((resource.data.createdBy == request.auth.uid
            && request.resource.data.createdByName == "Usuario eliminado")
          || (resource.data.createdBy != request.auth.uid
            && request.resource.data.createdByName == resource.data.createdByName))
        && request.resource.data.participantIds == resource.data.participantIds
        && request.resource.data.participantNames.size() == resource.data.participantNames.size();
    }

    function deletingOwnedSpace(spaceId) {
      return isOwner(spaceId) && !existsAfter(spacePath(spaceId));
    }

    match /spaces/{spaceId} {
      allow get: if isActiveMember(spaceId);
      allow list: if false;
      allow create: if validNewSpace(spaceId);
      allow update: if validSpaceRename(spaceId)
        || validOwnershipTransfer(spaceId)
        || validMemberCountDecrease(spaceId)
        || validMemberCountIncrease(spaceId);
      allow delete: if isOwner(spaceId);

      match /tasks/{taskId} {
        allow read: if isActiveMember(spaceId);
        allow create: if validNewTask(spaceId);
        allow update: if validTaskUpdate(spaceId)
          || validTaskAnonymization(spaceId)
          || validPendingTaskUnassignment(spaceId);
        allow delete: if isActiveMember(spaceId);
      }

      match /shoppingItems/{itemId} {
        allow read: if isActiveMember(spaceId);
        allow create: if validNewShoppingItem(spaceId);
        allow update: if validShoppingItemUpdate(spaceId)
          || validShoppingAnonymization(spaceId);
        allow delete: if isActiveMember(spaceId);
      }

      match /events/{eventId} {
        allow read: if isActiveMember(spaceId);
        allow create: if validNewEvent(spaceId);
        allow update: if validEventUpdate(spaceId)
          || validEventAnonymization(spaceId);
        allow delete: if isActiveMember(spaceId);
      }

      match /meals/{mealId} {
        allow read: if isActiveMember(spaceId);
        allow create: if validNewMeal(spaceId);
        allow update: if validMealUpdate(spaceId)
          || validMealAnonymization(spaceId);
        allow delete: if isActiveMember(spaceId);
      }

      match /{document=**} {
        allow read, write: if false;
      }
    }

    function validMembershipDocument(membershipId) {
      return request.resource.data.keys().hasAll([
          "spaceId",
          "userId",
          "displayName",
          "role",
          "status",
          "joinedAt"
        ])
        && request.resource.data.keys().hasOnly([
          "spaceId",
          "userId",
          "displayName",
          "role",
          "status",
          "joinedAt",
          "joinedViaInvitationId"
        ])
        && membershipId == request.resource.data.spaceId + "_" + request.resource.data.userId
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() > 0
        && request.resource.data.displayName.size() <= 60
        && request.resource.data.status == "ACTIVE";
    }

    function validInitialOwnerMembership(membershipId) {
      let spaceId = request.resource.data.spaceId;
      let createdSpace = getAfter(spacePath(spaceId));
      return verifiedUser()
        && validMembershipDocument(membershipId)
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.role == "OWNER"
        && !request.resource.data.keys().hasAny(["joinedViaInvitationId"])
        && request.resource.data.joinedAt == request.time
        && !exists(spacePath(spaceId))
        && createdSpace.data.ownerId == request.auth.uid
        && createdSpace.data.createdBy == request.auth.uid
        && createdSpace.data.memberCount == 1;
    }

    function validOwnershipRoleChange(spaceId) {
      let previousOwnerId = get(spacePath(spaceId)).data.ownerId;
      let newOwnerId = getAfter(spacePath(spaceId)).data.ownerId;
      return isOwner(spaceId)
        && newOwnerId != previousOwnerId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["role"])
        && request.resource.data.spaceId == resource.data.spaceId
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.status == "ACTIVE"
        && getAfter(membershipPath(spaceId, previousOwnerId)).data.role == "MEMBER"
        && getAfter(membershipPath(spaceId, newOwnerId)).data.role == "OWNER"
        && (
          (
            resource.data.userId == previousOwnerId
            && resource.data.role == "OWNER"
            && request.resource.data.role == "MEMBER"
          )
          || (
            resource.data.userId == newOwnerId
            && resource.data.role == "MEMBER"
            && request.resource.data.role == "OWNER"
          )
        );
    }

    function validMembershipRemoval(spaceId) {
      let targetUserId = resource.data.userId;
      let spaceBefore = get(spacePath(spaceId));
      let spaceAfter = getAfter(spacePath(spaceId));
      return isActiveMember(spaceId)
        && resource.data.status == "ACTIVE"
        && resource.data.role == "MEMBER"
        && (targetUserId == request.auth.uid || isOwner(spaceId))
        && spaceAfter.data.ownerId == spaceBefore.data.ownerId
        && spaceAfter.data.memberCount == spaceBefore.data.memberCount - 1
        && spaceAfter.data.lastMembershipChangeUserId == targetUserId
        && spaceAfter.data.updatedAt == request.time;
    }

    function validInvitationMembership(membershipId) {
      let spaceId = request.resource.data.spaceId;
      let invitationId = request.resource.data.joinedViaInvitationId;
      let invitationBefore = get(invitationPath(invitationId));
      let invitationAfter = getAfter(invitationPath(invitationId));
      let spaceBefore = get(spacePath(spaceId));
      let spaceAfter = getAfter(spacePath(spaceId));
      return verifiedUser()
        && validMembershipDocument(membershipId)
        && request.resource.data.keys().hasAny(["joinedViaInvitationId"])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.role == "MEMBER"
        && request.resource.data.joinedAt == request.time
        && invitationId is string
        && invitationBefore.data.spaceId == spaceId
        && invitationBefore.data.status == "ACTIVE"
        && invitationBefore.data.expiresAt > request.time
        && invitationAfter.data.status == "USED"
        && invitationAfter.data.usedBy == request.auth.uid
        && invitationAfter.data.usedAt == request.time
        && spaceBefore.data.memberCount < 10
        && spaceAfter.data.memberCount == spaceBefore.data.memberCount + 1
        && spaceAfter.data.lastMembershipChangeUserId == request.auth.uid
        && spaceAfter.data.updatedAt == request.time;
    }

    match /memberships/{membershipId} {
      allow get: if verifiedUser()
        && (
          resource.data.userId == request.auth.uid
          || isActiveMember(resource.data.spaceId)
        );
      allow list: if verifiedUser()
        && (
          resource.data.userId == request.auth.uid
          || isActiveMember(resource.data.spaceId)
        );
      allow create: if validInitialOwnerMembership(membershipId)
        || validInvitationMembership(membershipId);
      allow update: if validOwnershipRoleChange(resource.data.spaceId);
      allow delete: if validMembershipRemoval(resource.data.spaceId)
        || deletingOwnedSpace(resource.data.spaceId);
    }

    function validNewInvitation(invitationId) {
      return verifiedUser()
        && invitationId.matches('^[A-Z2-7]{32}$')
        && request.resource.data.keys().hasAll([
          "spaceId",
          "createdBy",
          "createdAt",
          "expiresAt",
          "status",
          "usedBy",
          "usedAt",
          "revokedAt"
        ])
        && request.resource.data.keys().hasOnly([
          "spaceId",
          "createdBy",
          "createdAt",
          "expiresAt",
          "status",
          "usedBy",
          "usedAt",
          "revokedAt"
        ])
        && request.resource.data.spaceId is string
        && isOwner(request.resource.data.spaceId)
        && get(spacePath(request.resource.data.spaceId)).data.memberCount < 10
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.createdAt == request.time
        && request.resource.data.expiresAt is timestamp
        && request.resource.data.expiresAt > request.time + duration.value(71, 'h')
        && request.resource.data.expiresAt <= request.time + duration.value(72, 'h')
        && request.resource.data.status == "ACTIVE"
        && request.resource.data.usedBy == null
        && request.resource.data.usedAt == null
        && request.resource.data.revokedAt == null;
    }

    function validInvitationConsumption(invitationId) {
      let spaceId = resource.data.spaceId;
      let membershipAfter = getAfter(membershipPath(spaceId, request.auth.uid));
      let spaceBefore = get(spacePath(spaceId));
      let spaceAfter = getAfter(spacePath(spaceId));
      return verifiedUser()
        && resource.data.status == "ACTIVE"
        && resource.data.expiresAt > request.time
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["status", "usedBy", "usedAt"])
        && request.resource.data.status == "USED"
        && request.resource.data.usedBy == request.auth.uid
        && request.resource.data.usedAt == request.time
        && membershipAfter.data.joinedViaInvitationId == invitationId
        && membershipAfter.data.userId == request.auth.uid
        && membershipAfter.data.spaceId == spaceId
        && membershipAfter.data.role == "MEMBER"
        && membershipAfter.data.status == "ACTIVE"
        && spaceBefore.data.memberCount < 10
        && spaceAfter.data.memberCount == spaceBefore.data.memberCount + 1
        && spaceAfter.data.lastMembershipChangeUserId == request.auth.uid
        && spaceAfter.data.updatedAt == request.time;
    }

    function validInvitationRevocation() {
      return isOwner(resource.data.spaceId)
        && resource.data.status == "ACTIVE"
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["status", "revokedAt"])
        && request.resource.data.status == "REVOKED"
        && request.resource.data.revokedAt == request.time;
    }

    match /invitations/{invitationId} {
      allow get: if verifiedUser();
      allow list: if verifiedUser() && isOwner(resource.data.spaceId);
      allow create: if validNewInvitation(invitationId);
      allow update: if validInvitationConsumption(invitationId)
        || validInvitationRevocation();
      allow delete: if isOwner(resource.data.spaceId);
    }

    function validPendingTaskUnassignment(spaceId) {
      let targetUserId = resource.data.assigneeId;
      let spaceAfter = getAfter(spacePath(spaceId));
      return isActiveMember(spaceId)
        && resource.data.status == "TODO"
        && targetUserId is string
        && request.resource.data.assigneeId == null
        && request.resource.data.assigneeName == null
        && request.resource.data.updatedBy == request.auth.uid
        && request.resource.data.updatedAt == request.time
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["assigneeId", "assigneeName", "updatedBy", "updatedAt"])
        && exists(membershipPath(spaceId, targetUserId))
        && get(membershipPath(spaceId, targetUserId)).data.role == "MEMBER"
        && !existsAfter(membershipPath(spaceId, targetUserId))
        && spaceAfter.data.lastMembershipChangeUserId == targetUserId
        && (targetUserId == request.auth.uid || isOwner(spaceId));
    }

    function recipeAdmins() {
      // Cuentas que pueden publicar/curar recetas del catálogo común (GLOBAL). Debe mantenerse
      // sincronizada con RecipeAdmins.uids en la app. Añadir/rotar: docs/RECIPES_ADMIN.md.
      return [
        "dWWH7eRhHEPopJf5BHPB3Dp6fry1", // luna.cerralbo.davi@gmail.com
      ];
    }

    function isRecipeAdmin() {
      return verifiedUser() && request.auth.uid in recipeAdmins();
    }

    function validRecipeShape() {
      return request.resource.data.keys().hasAll([
          "ownerUid", "visibility", "title", "description", "category",
          "createdBy", "createdByName", "createdAt", "updatedBy", "updatedAt"
        ])
        && request.resource.data.keys().hasOnly([
          "ownerUid", "visibility", "title", "description", "category",
          "createdBy", "createdByName", "createdAt", "updatedBy", "updatedAt", "sourceRecipeId",
          "ingredients"
        ])
        && (!request.resource.data.keys().hasAny(["sourceRecipeId"])
          || request.resource.data.sourceRecipeId == null
          || request.resource.data.sourceRecipeId is string)
        && (!request.resource.data.keys().hasAny(["ingredients"])
          || (request.resource.data.ingredients is list
            && request.resource.data.ingredients.size() <= 50))
        && request.resource.data.ownerUid is string
        && request.resource.data.visibility in ["GLOBAL", "PRIVATE"]
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 120
        && (request.resource.data.description == null
          || (request.resource.data.description is string && request.resource.data.description.size() <= 1000))
        && (request.resource.data.category == null
          || (request.resource.data.category is string && request.resource.data.category.size() <= 60))
        && request.resource.data.createdBy is string
        && request.resource.data.createdByName is string
        && request.resource.data.createdByName.size() > 0
        && request.resource.data.createdByName.size() <= 60
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedBy is string
        && request.resource.data.updatedAt is timestamp;
    }

    function validNewRecipe() {
      return verifiedUser() && validRecipeShape()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.createdBy == request.auth.uid && request.resource.data.createdAt == request.time
        && request.resource.data.updatedBy == request.auth.uid && request.resource.data.updatedAt == request.time
        && (request.resource.data.visibility == "PRIVATE" || isRecipeAdmin());
    }

    function ownsOrCuratesRecipe() {
      return verifiedUser()
        && (resource.data.ownerUid == request.auth.uid
          || (resource.data.visibility == "GLOBAL" && isRecipeAdmin()));
    }

    function validRecipeUpdate() {
      return ownsOrCuratesRecipe() && validRecipeShape()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["title", "description", "category", "ingredients", "updatedBy", "updatedAt"])
        && request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.visibility == resource.data.visibility
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdByName == resource.data.createdByName
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedBy == request.auth.uid && request.resource.data.updatedAt == request.time;
    }

    function validRecipeAnonymization() {
      return verifiedUser()
        && resource.data.ownerUid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["createdByName"])
        && request.resource.data.createdByName == "Usuario eliminado";
    }

    match /recipes/{recipeId} {
      allow get: if verifiedUser()
        && (resource.data.visibility == "GLOBAL" || resource.data.ownerUid == request.auth.uid);
      allow list: if verifiedUser()
        && (resource.data.visibility == "GLOBAL" || resource.data.ownerUid == request.auth.uid);
      allow create: if validNewRecipe();
      allow update: if validRecipeUpdate()
        || validRecipeAnonymization();
      allow delete: if ownsOrCuratesRecipe();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
