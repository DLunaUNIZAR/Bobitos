{
  "name": "bobitos-firebase-local",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "emulators": "firebase emulators:start --project demo-bobitos",
    "seed:emulators": "FIRESTORE_EMULATOR_HOST=127.0.0.1:8080 node scripts/seed-emulators.mjs",
    "test:emulators": "firebase emulators:exec --only auth,firestore --project demo-bobitos \"node --test tests/firebase-emulators.test.mjs\""
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "5.0.1",
    "firebase": "12.16.0",
    "firebase-tools": "15.23.0"
  }
}
